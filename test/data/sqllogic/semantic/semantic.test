-- setup: INSERT INTO t VALUES(30, 40);
SELECT a FROM t WHERE a IN (SELECT b FROM t);
----
10
20

-- name: semantic_in_subquery_or_where
-- source: semantic/in_subquery_or_where
-- sort: rowsort
-- setup: CREATE TABLE t(a INTEGER, b INTEGER, c INTEGER);
-- setup: INSERT INTO t VALUES(1, 5, 1);
-- setup: INSERT INTO t VALUES(2, 15, 2);
-- setup: INSERT INTO t VALUES(3, 25, 3);
SELECT a FROM t WHERE a IN (SELECT c FROM t WHERE c > 1 OR b >= 15);
----
2
3

