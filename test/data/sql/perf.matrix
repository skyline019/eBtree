setup: "INSERT INTO a (key, value) VALUES ('k1', '1')"
setup: "INSERT INTO b (key, value) VALUES ('k1', '1')"
exec: "SELECT a.key FROM a JOIN b ON a.key=b.key /* @max_pages=0 */"
expect: mic_violation
