case: window_00
parse: "SELECT ROW_NUMBER() OVER (ORDER BY a) FROM t"
expect_kind: kWindowSelect
---
case: window_01
parse: "SELECT RANK() OVER (ORDER BY a) FROM t"
expect_kind: kWindowSelect
---
case: window_02
parse: "SELECT DENSE_RANK() OVER (ORDER BY a) FROM t"
expect_kind: kWindowSelect
---
case: window_03
parse: "SELECT SUM(a) OVER (ORDER BY a) FROM t"
expect_kind: kWindowSelect
---
case: window_04
parse: "SELECT AVG(a) OVER (ORDER BY a) FROM t"
expect_kind: kWindowSelect
---
case: window_05
parse: "SELECT COUNT(a) OVER (ORDER BY a) FROM t"
expect_kind: kWindowSelect
---
case: window_06
parse: "SELECT MIN(a) OVER (ORDER BY a) FROM t"
expect_kind: kWindowSelect
---
case: window_07
parse: "SELECT MAX(a) OVER (ORDER BY a) FROM t"
expect_kind: kWindowSelect
---
case: window_08
parse: "SELECT ROW_NUMBER() OVER (PARTITION BY b ORDER BY a) FROM t"
expect_kind: kWindowSelect
---
case: window_09
parse: "SELECT ROW_NUMBER() OVER (ORDER BY a DESC) FROM t"
expect_kind: kWindowSelect
