---
case: adv_nested_exists
parse: "SELECT a.key FROM a WHERE EXISTS (SELECT b.key FROM b WHERE b.key = a.key AND EXISTS (SELECT a.key FROM a WHERE a.key = b.key))"
expect_kind: kSelect
expect_subquery: 1
