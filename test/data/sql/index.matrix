case: create_index_parse
parse: "CREATE INDEX idx_val ON t (value)"
expect_kind: kCreateIndex
---
case: create_unique_index_parse
parse: "CREATE UNIQUE INDEX idx_key ON t (key)"
expect_kind: kCreateIndex
---
case: drop_index_parse
parse: "DROP INDEX idx_val"
expect_kind: kDropIndex
---
case: index_scan_eq
setup: "CREATE TABLE t (key TEXT PRIMARY KEY, value TEXT)"
setup: "INSERT INTO t (key, value) VALUES ('k1', 'v1')"
setup: "CREATE INDEX idx_val ON t (value)"
exec: "SELECT key, value FROM t WHERE value = 'v1'"
expect: ok
expect_rows: 1
expect_value: v1
---
case: index_scan_miss
setup: "CREATE TABLE t (key TEXT PRIMARY KEY, value TEXT)"
setup: "INSERT INTO t (key, value) VALUES ('k1', 'v1')"
setup: "CREATE INDEX idx_val ON t (value)"
exec: "SELECT key, value FROM t WHERE value = 'missing'"
expect: ok
expect_rows: 0
---
case: index_maintain_insert
setup: "CREATE TABLE t (key TEXT PRIMARY KEY, value TEXT)"
setup: "CREATE INDEX idx_val ON t (value)"
setup: "INSERT INTO t (key, value) VALUES ('k2', 'v2')"
exec: "SELECT key FROM t WHERE value = 'v2'"
expect: ok
expect_rows: 1
---
case: explain_index_scan
setup: "CREATE TABLE t (key TEXT PRIMARY KEY, value TEXT)"
setup: "CREATE INDEX idx_val ON t (value)"
exec: "EXPLAIN QUERY PLAN SELECT key FROM t WHERE value = 'x'"
expect: ok
expect_rows: 1
---
case: drop_index_exec
setup: "CREATE TABLE t (key TEXT PRIMARY KEY, value TEXT)"
setup: "CREATE INDEX idx_val ON t (value)"
setup: "DROP INDEX idx_val"
exec: "SELECT key FROM t"
expect: ok
expect_rows: 0
